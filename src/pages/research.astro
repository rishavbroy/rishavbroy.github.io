---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CollectionFilters from "../components/CollectionFilters.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { getProjectTaxonomy, sortProjects } from "../lib/projects";

const projects = sortProjects(await getCollection("projects"));
const taxonomy = getProjectTaxonomy(projects);
---

<BaseLayout title="Research" description="Research projects by Rishav Roy in development, political economy, econometrics, macroeconomics, and language models.">
  <section class="container page-hero">
    <SectionHeading
      eyebrow="Research"
      title="Projects and research questions"
      description="Use the filters to scan projects by field, method, or status."
    />
    <CollectionFilters
      id="research"
      label="Filter research projects"
      searchPlaceholder="Search projects by title, question, topic, or skill"
      itemSingular="project"
      itemPlural="projects"
      groups={[
        { key: "status", label: "Status", options: taxonomy.statuses, defaultOpen: true },
        { key: "topics", label: "Topic", options: taxonomy.topics, defaultOpen: true },
        { key: "skills", label: "Skill or technique", options: taxonomy.skills, defaultOpen: false }
      ]}
    />
  </section>

  <section class="container section compact-section">
    <div class="card-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <p class="no-filter-results" data-filter-empty="research" hidden>No projects match those filters.</p>
    <p class="collection-footnote">Each project is a structured Markdown entry with status, topics, skills, question, description, links, and a featured flag.</p>
  </section>
</BaseLayout>
