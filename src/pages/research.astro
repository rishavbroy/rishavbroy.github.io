---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CollectionFilters from "../components/CollectionFilters.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { getProjectTaxonomy, getProjectTimeline, sortProjects } from "../lib/projects";
import { collectionPageStructuredData } from "../lib/structuredData";

const description = "Research projects by Rishav Roy in development, political economy, econometrics, macroeconomics, and language models.";
const projects = sortProjects(await getCollection("projects"));
const taxonomy = getProjectTaxonomy(projects);
const timeline = getProjectTimeline(projects);
const structuredData = collectionPageStructuredData({
  path: "/research/",
  name: "Research | Rishav Roy",
  description
});
---

<BaseLayout title="Research" description={description} jsonLd={structuredData}>
  <section class="container page-hero">
    <SectionHeading eyebrow="Research" title="Projects and research questions" />
    <CollectionFilters
      id="research"
      label="Filter research projects"
      searchPlaceholder="Search projects by title, mentor, question, topic, or skill"
      itemSingular="project"
      itemPlural="projects"
      range={{ key: "period", label: "Date", points: timeline }}
      groups={[
        { key: "status", label: "Status", options: taxonomy.statuses },
        { key: "topics", label: "Topic", options: taxonomy.topics },
        { key: "skills", label: "Skill", options: taxonomy.skills }
      ]}
    />
  </section>

  <section class="container section compact-section">
    <div class="card-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <p class="no-filter-results" data-filter-empty="research" hidden>No projects match those filters.</p>
  </section>
</BaseLayout>
