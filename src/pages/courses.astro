---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CollectionFilters from "../components/CollectionFilters.astro";
import CourseCard from "../components/CourseCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { getCourseTaxonomy, sortCourses } from "../lib/courses";
import { collectionPageStructuredData } from "../lib/structuredData";

const description = "Selected coursework by Rishav Roy in graduate economics, mathematics, data science, machine learning, political economy, and development.";
const courses = sortCourses(await getCollection("courses"));
const taxonomy = getCourseTaxonomy(courses);
const structuredData = collectionPageStructuredData({
  path: "/courses/",
  name: "Courses | Rishav Roy",
  description
});
---

<BaseLayout title="Courses" description={description} jsonLd={structuredData}>
  <section class="container page-hero">
    <SectionHeading eyebrow="Courses" title="Selected coursework" />
    <CollectionFilters
      id="courses"
      label="Filter selected coursework"
      searchPlaceholder="Search courses by title, code, instructor, department, term, type, topic, or achievement"
      itemSingular="course"
      itemPlural="courses"
      groups={[
        { key: "semester", label: "Term", options: taxonomy.semesters },
        { key: "departments", label: "Department", options: taxonomy.departments },
        { key: "types", label: "Course type", options: taxonomy.types },
        { key: "topics", label: "Topic", options: taxonomy.topics },
        { key: "achievements", label: "Achievement", options: taxonomy.achievements }
      ]}
    />
  </section>

  <section class="container section compact-section">
    <div class="course-grid">
      {courses.map((course) => <CourseCard course={course} />)}
    </div>
    <p class="no-filter-results" data-filter-empty="courses" hidden>No courses match those filters.</p>
  </section>
</BaseLayout>
