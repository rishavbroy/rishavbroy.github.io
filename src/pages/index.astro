---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { getFeaturedProjects } from "../lib/projects";

const featuredProjects = getFeaturedProjects(await getCollection("projects"));
---

<BaseLayout>
  <section class="hero container section-xl">
    <div class="hero-image-wrap">
      <picture>
        <source srcset="/images/headshot-480.webp 480w, /images/headshot-960.webp 960w" type="image/webp" />
        <img
          src="/images/headshot.jpg"
          alt="Portrait of Rishav Roy at sunset"
          class="hero-image"
          width="960"
          height="1440"
          loading="eager"
        />
      </picture>
    </div>

    <div class="hero-copy">
      <p class="eyebrow">UW–Madison B.S., May 2026 · Economics · Mathematics · Data Science</p>
      <h1>Rishav Roy</h1>
      <p class="hero-identity">
        A triple major with top scores in PhD-level economics, building the toolkit needed to study pressing issues in the empirical analysis of political economy, development, and policy.
      </p>
      <div class="button-row">
        <a class="button button-primary" href="#story">My Story</a>
        <a class="button button-secondary" href="#current-projects">Current Projects</a>
        <a class="button button-secondary" href="#interests">My Interests</a>
      </div>
    </div>
  </section>

  <section id="story" class="container section story-section">
    <p class="eyebrow">My Story</p>
    <div class="story-prose">
      <p class="story-statement">
        In just three academic years, I began and completed three majors in Economics, Mathematics, and Data Science.
      </p>
      <p class="story-statement">
        In just two academic years, I outscored all students in multiple PhD-level economics and master’s-level mathematics courses, ultimately earning a 3.9 GPA over the same period in which I completed the entirety of the first-year Economics PhD courseload plus 18 undergraduate-level courses.
      </p>
      <p>
        It is accomplishments like this that testify to how well I, in a marathon of high-stakes work, in settings both intellectually rigorous and breakneck, am able to thrive.
      </p>
      <p>
        I pride myself on being a lifelong learner—on my motivation and curiosity and ability to ask penetrating, creative questions. But it is only when combined with exceptional critical thinking abilities, advanced communication skills, and deep scientific understanding that this mixture can become potent. It is precisely this combination that I look forward to applying in my work alongside you.
      </p>
    </div>
  </section>

  <section id="current-projects" class="container section">
    <SectionHeading eyebrow="My Current Projects" title="Research questions I am actively developing">
      <p>All of my projects can be found on the <a href="/research/">Research page</a>.</p>
    </SectionHeading>
    <div class="card-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section id="interests" class="container section">
    <SectionHeading
      eyebrow="My Interests"
      title="Institutions, power, beliefs, and development"
      description="My central question is why some societies channel individual incentives into innovation, trust, and broad prosperity while others get stuck in equilibria shaped by coercion, instability, inequality, or institutional failure."
    />
    <div class="interest-grid">
      <article class="interest-item">
        <h3>Political economy of development</h3>
        <p>How elite power, state capacity, and institutional design shape growth, innovation, and structural transformation.</p>
      </article>
      <article class="interest-item">
        <h3>Equilibrium selection</h3>
        <p>How norms, beliefs, repeated interactions, and coordination failures make good and bad equilibria self-reinforcing.</p>
      </article>
      <article class="interest-item">
        <h3>Measurement and empirical methods</h3>
        <p>How causal inference, text-as-data, and econometric theory can make broad social questions empirically tractable.</p>
      </article>
    </div>
  </section>
</BaseLayout>
