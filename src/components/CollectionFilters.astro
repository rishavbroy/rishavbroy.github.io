---
interface FilterGroup {
  key: string;
  label: string;
  options: string[];
  allLabel?: string;
  defaultOpen?: boolean;
}

interface RangePoint {
  label: string;
  value: number;
}

interface RangeFilter {
  key: string;
  label: string;
  points: RangePoint[];
}

interface Props {
  id: string;
  label: string;
  searchLabel?: string;
  searchPlaceholder?: string;
  itemSingular: string;
  itemPlural: string;
  groups: FilterGroup[];
  range?: RangeFilter;
}

const {
  id,
  label,
  searchLabel = "Search",
  searchPlaceholder = "Search...",
  itemSingular,
  itemPlural,
  groups,
  range
} = Astro.props;

const hasRange = range && range.points.length > 1;
const rangeStartLabel = hasRange ? range.points[0].label : "";
const rangeEndLabel = hasRange ? range.points[range.points.length - 1].label : "";
const rangeMax = hasRange ? range.points.length - 1 : 0;
const rangeLabels = hasRange ? range.points.map((point) => point.label).join("|") : "";
const rangeValues = hasRange ? range.points.map((point) => String(point.value)).join("|") : "";
const rangeDatalistId = hasRange ? `${id}-${range.key}-marks` : "";
---

<section class="filter-panel" data-filter-root={id} data-item-singular={itemSingular} data-item-plural={itemPlural} aria-label={label}>
  <div class="filter-search">
    <label for={`${id}-search`}>{searchLabel}</label>
    <input id={`${id}-search`} type="search" placeholder={searchPlaceholder} autocomplete="off" data-filter-search />
  </div>

  <div class="filter-groups" aria-label={`${label} controls`}>
    {hasRange && range && (
      <details
        class="filter-group range-filter-group"
        data-filter-range={range.key}
        data-range-labels={rangeLabels}
        data-range-values={rangeValues}
      >
        <summary>
          <span>{range.label}</span>
          <span class="filter-summary-count" data-range-summary>{rangeStartLabel}–{rangeEndLabel}</span>
        </summary>
        <div class="range-filter">
          <div class="range-slider" data-range-slider>
            <div class="range-slider-track" aria-hidden="true"></div>
            <input type="range" min="0" max={rangeMax} step="1" value="0" list={rangeDatalistId} aria-label={`${range.label} start`} data-range-start />
            <input type="range" min="0" max={rangeMax} step="1" value={rangeMax} list={rangeDatalistId} aria-label={`${range.label} end`} data-range-end />
          </div>
          <datalist id={rangeDatalistId}>
            {range.points.map((point, index) => <option value={index} label={point.label} />)}
          </datalist>
          <div class="range-filter-bounds" aria-hidden="true">
            <span>{rangeStartLabel}</span>
            <span>{rangeEndLabel}</span>
          </div>
        </div>
      </details>
    )}

    {
      groups.map((group) => (
        <details class="filter-group" data-filter-group={group.key} open={group.defaultOpen === true ? true : undefined}>
          <summary>
            <span>{group.label}</span>
            <span class="filter-summary-count" data-filter-summary>All</span>
          </summary>
          <div class="filter-options" role="group" aria-label={group.label}>
            <button type="button" class="filter-button" data-filter-all aria-pressed="true">
              {group.allLabel ?? "All"}
            </button>
            {group.options.map((option) => (
              <button type="button" class="filter-button" data-filter-value={option} aria-pressed="false">
                {option}
              </button>
            ))}
          </div>
        </details>
      ))
    }
  </div>

  <div class="filter-footer">
    <p class="filter-count" data-filter-count aria-live="polite"></p>
    <button type="button" class="filter-reset" data-filter-reset>Reset filters</button>
  </div>
</section>

<script>
  function normalize(value) {
    return String(value || "").trim().toLowerCase();
  }

  function tokenize(value) {
    return normalize(value).split("|").filter(Boolean);
  }

  function getSelectedLabels(group) {
    return Array.from(group.querySelectorAll("[data-filter-value][aria-pressed='true']")).map((button) => button.textContent.trim());
  }

  function summarizeGroup(group) {
    const summary = group.querySelector("[data-filter-summary]");
    if (!summary) return;

    const selectedLabels = getSelectedLabels(group);
    if (selectedLabels.length === 0) {
      summary.textContent = "All";
    } else if (selectedLabels.length === 1) {
      summary.textContent = selectedLabels[0];
    } else {
      summary.textContent = `${selectedLabels.length} selected`;
    }
  }

  function setupFilters(root) {
    const scope = root.dataset.filterRoot;
    const cards = Array.from(document.querySelectorAll(`[data-filter-card="${scope}"]`));
    const empty = document.querySelector(`[data-filter-empty="${scope}"]`);
    const searchInput = root.querySelector("[data-filter-search]");
    const count = root.querySelector("[data-filter-count]");
    const reset = root.querySelector("[data-filter-reset]");
    const itemSingular = root.dataset.itemSingular || "item";
    const itemPlural = root.dataset.itemPlural || "items";
    const state = new Map();
    const rangeGroup = root.querySelector("[data-filter-range]");
    const rangeState = rangeGroup
      ? {
          key: rangeGroup.dataset.filterRange,
          values: String(rangeGroup.dataset.rangeValues || "").split("|").map(Number),
          labels: String(rangeGroup.dataset.rangeLabels || "").split("|"),
          start: rangeGroup.querySelector("[data-range-start]"),
          end: rangeGroup.querySelector("[data-range-end]"),
          slider: rangeGroup.querySelector("[data-range-slider]"),
          summary: rangeGroup.querySelector("[data-range-summary]")
        }
      : null;

    function getRangeSelection() {
      if (!rangeState) return null;
      const startIndex = Number(rangeState.start?.value || 0);
      const endIndex = Number(rangeState.end?.value || rangeState.values.length - 1);
      const lowerIndex = Math.min(startIndex, endIndex);
      const upperIndex = Math.max(startIndex, endIndex);

      return {
        start: rangeState.values[lowerIndex],
        end: rangeState.values[upperIndex],
        startLabel: rangeState.labels[lowerIndex],
        endLabel: rangeState.labels[upperIndex]
      };
    }

    function updateRangeLabels() {
      const selection = getRangeSelection();
      if (!selection || !rangeState) return;
      const label = `${selection.startLabel}–${selection.endLabel}`;
      if (rangeState.summary) rangeState.summary.textContent = label;

      if (rangeState.slider) {
        const maxIndex = Math.max(1, rangeState.values.length - 1);
        const startIndex = Number(rangeState.start?.value || 0);
        const endIndex = Number(rangeState.end?.value || maxIndex);
        const lowerIndex = Math.min(startIndex, endIndex);
        const upperIndex = Math.max(startIndex, endIndex);
        rangeState.slider.style.setProperty("--range-start", `${(lowerIndex / maxIndex) * 100}%`);
        rangeState.slider.style.setProperty("--range-end", `${(upperIndex / maxIndex) * 100}%`);
      }
    }

    function updateCount(visibleCount) {
      if (!count) return;
      const label = visibleCount === 1 ? itemSingular : itemPlural;
      count.textContent = `${visibleCount} of ${cards.length} ${label} shown`;
    }

    function applyFilters() {
      const query = normalize(searchInput?.value);
      let visibleCount = 0;

      for (const card of cards) {
        const matchesGroups = Array.from(state.entries()).every(([key, selected]) => {
          if (selected.size === 0) return true;
          const cardValues = tokenize(card.dataset[key]);
          return Array.from(selected).some((value) => cardValues.includes(value));
        });
        const rangeSelection = getRangeSelection();
        const matchesRange = !rangeSelection || (() => {
          const cardStart = Number(card.dataset[`${rangeState.key}Start`]);
          const cardEnd = Number(card.dataset[`${rangeState.key}End`]);
          if (!Number.isFinite(cardStart) || !Number.isFinite(cardEnd)) return true;
          return cardStart <= rangeSelection.end && cardEnd >= rangeSelection.start;
        })();
        const matchesSearch = !query || normalize(card.dataset.search).includes(query);
        const visible = matchesGroups && matchesRange && matchesSearch;
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      }

      if (empty) empty.hidden = visibleCount !== 0;
      updateCount(visibleCount);
    }

    function updateGroupButtons(group, selected) {
      const allButton = group.querySelector("[data-filter-all]");
      allButton?.setAttribute("aria-pressed", String(selected.size === 0));

      for (const button of group.querySelectorAll("[data-filter-value]")) {
        button.setAttribute("aria-pressed", String(selected.has(normalize(button.dataset.filterValue))));
      }

      summarizeGroup(group);
    }

    for (const group of root.querySelectorAll("[data-filter-group]")) {
      const key = group.dataset.filterGroup;
      const selected = new Set();
      state.set(key, selected);

      group.querySelector("[data-filter-all]")?.addEventListener("click", () => {
        selected.clear();
        updateGroupButtons(group, selected);
        applyFilters();
      });

      for (const button of group.querySelectorAll("[data-filter-value]")) {
        button.addEventListener("click", () => {
          const value = normalize(button.dataset.filterValue);
          if (selected.has(value)) {
            selected.delete(value);
          } else {
            selected.add(value);
          }
          updateGroupButtons(group, selected);
          applyFilters();
        });
      }

      updateGroupButtons(group, selected);
    }

    searchInput?.addEventListener("input", applyFilters);

    rangeState?.start?.addEventListener("input", () => {
      updateRangeLabels();
      applyFilters();
    });

    rangeState?.end?.addEventListener("input", () => {
      updateRangeLabels();
      applyFilters();
    });

    reset?.addEventListener("click", () => {
      if (searchInput) searchInput.value = "";
      if (rangeState) {
        rangeState.start.value = "0";
        rangeState.end.value = String(rangeState.values.length - 1);
        updateRangeLabels();
      }
      for (const group of root.querySelectorAll("[data-filter-group]")) {
        const selected = state.get(group.dataset.filterGroup);
        selected?.clear();
        updateGroupButtons(group, selected ?? new Set());
      }
      applyFilters();
    });

    updateRangeLabels();
    applyFilters();
  }

  for (const root of document.querySelectorAll("[data-filter-root]")) {
    setupFilters(root);
  }
</script>
