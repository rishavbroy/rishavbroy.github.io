---
import type { CollectionEntry } from "astro:content";
import PeopleList from "./PeopleList.astro";
import TagList from "./TagList.astro";
import { getCourseDepartment, orderCourseTypes } from "../lib/courses";
import { toFilterData, toSearchData } from "../lib/filterData";
import { getPeopleNames } from "../data/people";

interface Props {
  course: CollectionEntry<"courses">;
}

const { course } = Astro.props;
const { data } = course;
const filterScope = "courses";
const peopleContext = `course: ${data.title}`;
const professorNames = getPeopleNames(data.professors, peopleContext);
const department = getCourseDepartment(data.code);
const courseTypes = orderCourseTypes(data.types);
const searchData = toSearchData([
  data.title,
  data.code,
  department,
  data.semester,
  data.grade,
  data.audited ? "Audited" : undefined,
  data.achievements,
  courseTypes,
  data.topics,
  professorNames
]);
---

<article
  class="card course-card"
  data-filter-card={filterScope}
  data-semester={toFilterData(data.semester)}
  data-departments={toFilterData(department)}
  data-types={toFilterData(courseTypes)}
  data-topics={toFilterData(data.topics)}
  data-achievements={toFilterData(data.achievements)}
  data-search={searchData}
>
  <div class="course-card-header">
    <div>
      <p class="card-kicker">{data.semester}</p>
      <h3>{data.title}</h3>
      <p class="course-code">{data.code}</p>
      <PeopleList ids={data.professors} singularLabel="Instructor" pluralLabel="Instructors" context={peopleContext} />
    </div>
    {data.grade && <span class="grade-pill" aria-label={`Grade: ${data.grade}`}>{data.grade}</span>}
  </div>
  {data.audited && <span class="audit-pill">Audited</span>}
  <TagList tags={data.achievements} label={`Achievements for ${data.title}`} variant="achievement" />
  <TagList tags={courseTypes} label={`Course types for ${data.title}`} variant="type" />
  <TagList tags={data.topics} label={`Topics for ${data.title}`} variant="topic" />
  {data.syllabusUrl && (
    <div class="card-links">
      <a href={data.syllabusUrl}>Syllabus</a>
    </div>
  )}
</article>
