---
import type { CollectionEntry } from "astro:content";
import PeopleList from "./PeopleList.astro";
import TagList from "./TagList.astro";
import { toFilterData, toSearchData } from "../lib/filterData";
import { getPeopleNames } from "../data/people";

interface Props {
  course: CollectionEntry<"courses">;
}

const { course } = Astro.props;
const { data } = course;
const filterScope = "courses";
const peopleContext = `course: ${data.title}`;
const professorNames = getPeopleNames(data.professors, peopleContext);
const searchData = toSearchData([
  data.title,
  data.semester,
  data.grade,
  data.achievements,
  data.types,
  data.skills,
  professorNames
]);
---

<article
  class="card course-card"
  data-filter-card={filterScope}
  data-semester={toFilterData(data.semester)}
  data-types={toFilterData(data.types)}
  data-achievements={toFilterData(data.achievements)}
  data-search={searchData}
>
  <div class="course-card-header">
    <div>
      <p class="card-kicker">{data.semester}</p>
      <h3>{data.title}</h3>
    </div>
    {data.grade && <span class="grade-pill" aria-label={`Grade: ${data.grade}`}>{data.grade}</span>}
  </div>
  <PeopleList ids={data.professors} label="Professors" context={peopleContext} />
  <TagList tags={data.achievements} label={`Achievements for ${data.title}`} variant="achievement" />
  <TagList tags={data.types} label={`Types for ${data.title}`} variant="type" />
  <TagList tags={data.skills} label={`Skills for ${data.title}`} variant="skill" />
  {data.syllabusUrl && (
    <div class="card-links">
      <a href={data.syllabusUrl}>Syllabus</a>
    </div>
  )}
</article>
