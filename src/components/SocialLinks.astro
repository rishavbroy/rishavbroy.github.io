---
interface SocialLink {
  href: string;
  label: string;
  icon: "github" | "linkedin";
}

interface Props {
  links?: SocialLink[];
  label?: string;
}

const {
  label = "External profiles",
  links = [
    { href: "https://github.com/rishavbroy", label: "GitHub", icon: "github" },
    { href: "https://www.linkedin.com/in/roybrishav", label: "LinkedIn", icon: "linkedin" }
  ]
} = Astro.props;
---

<nav class="social-links" aria-label={label}>
  {
    links.map((link) => (
      <a class="social-link" href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label} title={link.label}>
        {
          link.icon === "github" ? (
            <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
              <path d="M12 0C5.37 0 0 5.48 0 12.25c0 5.42 3.44 10.01 8.2 11.64.6.11.82-.26.82-.59 0-.29-.01-1.25-.02-2.27-3.34.74-4.04-1.45-4.04-1.45-.55-1.42-1.34-1.8-1.34-1.8-1.09-.77.08-.75.08-.75 1.21.09 1.85 1.27 1.85 1.27 1.07 1.87 2.81 1.33 3.5 1.02.11-.79.42-1.33.76-1.64-2.67-.31-5.47-1.36-5.47-6.06 0-1.34.47-2.43 1.24-3.29-.12-.31-.54-1.56.12-3.25 0 0 1.01-.33 3.3 1.26A11.2 11.2 0 0 1 12 5.93c1.02 0 2.04.14 3 .41 2.29-1.59 3.3-1.26 3.3-1.26.66 1.69.24 2.94.12 3.25.77.86 1.24 1.95 1.24 3.29 0 4.71-2.81 5.75-5.49 6.06.43.38.82 1.13.82 2.28 0 1.64-.02 2.96-.02 3.36 0 .33.22.71.83.59A12.24 12.24 0 0 0 24 12.25C24 5.48 18.63 0 12 0Z" />
            </svg>
          ) : (
            <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
              <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.55 13.02H3.79V9h3.1v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45C23.2 24 24 23.23 24 22.27V1.73C24 .77 23.2 0 22.23 0Z" />
            </svg>
          )
        }
        <span class="sr-only">{link.label}</span>
      </a>
    ))
  }
</nav>
