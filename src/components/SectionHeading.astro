---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="section-heading">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  {title && <h2>{title}</h2>}
  {description && <p>{description}</p>}
  <slot />
</div>
