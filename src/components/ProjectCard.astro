---
import type { CollectionEntry } from "astro:content";
import PeopleList from "./PeopleList.astro";
import ProjectLinkList from "./ProjectLinkList.astro";
import InlineLinkText from "./InlineLinkText.astro";
import TagList from "./TagList.astro";
import { toFilterData, toSearchData } from "../lib/filterData";
import { getPeopleNames } from "../data/people";
import { getProjectStatusFilterValues } from "../lib/projects";
import { getPeriodValues } from "../lib/terms";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data } = project;
const filterScope = "research";
const peopleContext = `project: ${data.title}`;
const mentorNames = getPeopleNames(data.mentors, peopleContext);
const period = getPeriodValues(data.period);
const statusFilterValues = getProjectStatusFilterValues(project);
const searchData = toSearchData([
  data.title,
  data.status,
  data.question,
  data.shortDescription,
  data.topics,
  data.skills,
  data.period.label,
  mentorNames
]);
---

<article
  class:list={["card", "project-card", data.featured && "featured-project"]}
  data-filter-card={filterScope}
  data-status={toFilterData(statusFilterValues)}
  data-topics={toFilterData(data.topics)}
  data-skills={toFilterData(data.skills)}
  data-period-start={period.start}
  data-period-end={period.end}
  data-search={searchData}
>
  <div class="project-card-header">
    <div class="card-kicker">{data.status}</div>
    <div class="project-card-meta">
      <span class="project-period">{data.period.label}</span>
      {data.featured && <span class="featured-badge">Featured</span>}
    </div>
  </div>

  <h3>{data.title}</h3>
  <PeopleList ids={data.mentors} singularLabel="Mentor" pluralLabel="Mentors" context={peopleContext} />
  <p class="project-question"><strong>Question:</strong> {data.question}</p>
  <InlineLinkText text={data.shortDescription} className="project-description" />

  <div class="tag-groups">
    <div>
      <p class="tag-group-label">Topics</p>
      <TagList tags={data.topics} label={`Topics for ${data.title}`} variant="topic" />
    </div>
    <div>
      <p class="tag-group-label">Skills</p>
      <TagList tags={data.skills} label={`Skills for ${data.title}`} variant="skill" />
    </div>
  </div>

  <ProjectLinkList links={data.links} label={`Links for ${data.title}`} />
</article>
