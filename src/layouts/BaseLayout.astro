---
import { Font } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Rishav Roy",
  description = "Rishav Roy studies political economy, development, and the institutional dynamics that shape how societies escape or remain trapped in bad equilibria.",
  image = "/images/headshot-960.webp"
} = Astro.props;

const pageTitle = title === "Rishav Roy" ? title : `${title} | Rishav Roy`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const metaImageUrl = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en" data-js="false">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Rishav Roy" />
    <meta name="theme-color" content="#080504" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={metaImageUrl.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={metaImageUrl.href} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="icon" href="/images/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/images/favicon-32x32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
    <Font cssVariable="--font-source-sans-3" />
    <Font cssVariable="--font-spectral" />
    <!-- Uncomment the following to enable font "presets":
    <Font cssVariable="--font-lato" />
    <Font cssVariable="--font-ibm-plex-sans" />
    <Font cssVariable="--font-manrope" />
    <Font cssVariable="--font-plus-jakarta-sans" />
    <Font cssVariable="--font-cabinet-grotesk" />
    <Font cssVariable="--font-general-sans" />
    <Font cssVariable="--font-satoshi" />
    <Font cssVariable="--font-literata" />
    <Font cssVariable="--font-newsreader" />
    <Font cssVariable="--font-source-serif-4" />
    <Font cssVariable="--font-crimson-pro" />
    -->
    <script is:inline>document.documentElement.dataset.js = "true";</script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
